{% extends "layout/base.jinja" %}
{% block title %}{{ t('nav.history') }} - {{ app_name }}{% endblock %}

{% block content %}
<section class="card">
  <h1>{{ t('history.title') }}</h1>
  {% if items %}
    <ul class="song-list">
      {% for song in items %}
        <li data-song-id="{{ song.id }}" class="{% if not song.is_available %}song-unavailable{% endif %}">
          <div>
            <a href="{{ song.detail_url }}"><strong>{{ song.title }}</strong></a>
            <p>{{ song.artist }}</p>
            {% if not song.is_available %}<span class="badge">{{ t('song.unavailable') }}</span>{% endif %}
            <p class="muted small">{{ t('history.play_count', count=song.play_count) }}</p>
          </div>
          <div class="row-actions">
              <button
                type="button"
                class="play-one"
                data-context="auto"
                data-song='{{ {"id": song.id, "title": song.title, "artist": song.artist, "url": song.url, "detail_url": song.detail_url, "resume_at": song.last_position, "source_type": song.source_type, "source_url": song.source_url, "external_provider": song.external_provider, "youtube_video_id": song.youtube_video_id, "playback_mode": song.playback_mode, "is_available": song.is_available, "is_audio_playable": song.is_audio_playable}|tojson|safe }}'
              >{{ t('history.play_now') }}</button>
            <a class="btn secondary" href="{{ song.detail_url }}">{{ t('song.details') }}</a>
          </div>
        </li>
      {% endfor %}
    </ul>
    <div class="pagination">
      {% if page > 1 %}
        <a class="btn secondary" href="{{ url_for('accounts.listening_history', page=page-1) }}">{{ t('main.prev') }}</a>
      {% endif %}
      <span>{{ t('main.page', page=page, pages=pages) }}</span>
      {% if page < pages %}
        <a class="btn secondary" href="{{ url_for('accounts.listening_history', page=page+1) }}">{{ t('main.next') }}</a>
      {% endif %}
    </div>
  {% else %}
    <p>{{ t('history.empty') }}</p>
  {% endif %}
</section>

<script>
  window.PAGE_SONG_OBJECTS = [
  {% for song in items %}
    {{ {"id": song.id, "title": song.title, "artist": song.artist, "url": song.url, "detail_url": song.detail_url, "resume_at": song.last_position, "source_type": song.source_type, "source_url": song.source_url, "external_provider": song.external_provider, "youtube_video_id": song.youtube_video_id, "playback_mode": song.playback_mode, "is_available": song.is_available, "is_audio_playable": song.is_audio_playable}|tojson|safe }}{% if not loop.last %},{% endif %}
  {% endfor %}
  ];
</script>
{% endblock %}
