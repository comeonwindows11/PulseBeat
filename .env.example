MAIL_ENABLED=1
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_USE_TLS=1
MAIL_USE_SSL=0
MAIL_FROM=PulseBeat <your_email@gmail.com>
APP_BASE_URL=http://127.0.0.1:5000
PASSWORD_RESET_TOKEN_MAX_AGE=3600
PASSWORD_RESET_SALT=change-this-reset-salt
EMAIL_VERIFICATION_TOKEN_MAX_AGE=86400
EMAIL_VERIFICATION_SALT=change-this-email-verification-salt
TWO_FACTOR_CODE_MAX_AGE=600
TWO_FACTOR_TOGGLE_TOKEN_MAX_AGE=3600
TWO_FACTOR_TOGGLE_SALT=change-this-two-factor-toggle-salt
TWO_FACTOR_TOTP_PENDING_MAX_AGE=900
PLATFORM_RESET_TOKEN_MAX_AGE=1800
PLATFORM_RESET_SALT=change-this-platform-reset-salt
JS_SERVE_OBFUSCATED=1
SERVER_CACHE_DIR=
SERVER_CACHE_JSON_MAX_BYTES=20971520
SERVER_CACHE_JSON_MAX_FILES=500
PUBLIC_PROFILE_CACHE_TTL_SECONDS=180
PUBLIC_PLAYLIST_CACHE_TTL_SECONDS=180
POPULAR_PUBLIC_SONGS_CACHE_TTL_SECONDS=180
YOUTUBE_AUDIO_CACHE_ENABLED=1
YOUTUBE_AUDIO_CACHE_MAX_BYTES=536870912
YOUTUBE_AUDIO_CACHE_MAX_FILES=80

SERVER_STORAGE_MIN_FREE_BYTES=1
DATABASE_STORAGE_MIN_FREE_BYTES=67108864
DATABASE_STORAGE_CAPACITY_BYTES=0
REQUEST_TIMEOUT_SECONDS=20
SERVICE_OVERLOAD_ACTIVE_REQUESTS=18
SERVICE_OVERLOAD_BURST_REQUESTS=36
SERVICE_BURST_WINDOW_SECONDS=8
SERVICE_OVERLOAD_SLOW_REQUESTS=4
SERVICE_SLOW_WINDOW_SECONDS=180
SERVICE_LIMP_MODE_SECONDS=45
SERVICE_LATCH_OVERLOAD_EVENTS=3
SERVICE_LATCH_WINDOW_SECONDS=300
SERVICE_RECOVER_ACTIVE_REQUESTS=2
SERVICE_RECOVER_BURST_REQUESTS=6
ROBOT_WATCHDOG_WINDOW_SECONDS=8
ROBOT_WATCHDOG_MAX_REQUESTS=28
ROBOT_WATCHDOG_WRITE_WINDOW_SECONDS=20
ROBOT_WATCHDOG_MAX_WRITE_REQUESTS=10
ROBOT_WATCHDOG_BURST_WINDOW_SECONDS=2
