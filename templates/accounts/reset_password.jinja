{% extends "layout/base.jinja" %}
{% block title %}{{ t('auth.reset_password') }} - {{ app_name }}{% endblock %}

{% block content %}
<section class="auth-wrap">
  <div class="card auth-card">
    <h1>{{ t('auth.reset_password') }}</h1>
    <p class="muted">{{ t('auth.reset_password_help') }}</p>
    <p class="muted small">{{ t('auth.password_policy') }}</p>
    <form method="post" class="stack">
      <label>{{ t('account.new_password') }}
        <input type="password" name="new_password" minlength="6" required>
      </label>
      <label>{{ t('account.confirm_password') }}
        <input type="password" name="confirm_password" minlength="6" required>
      </label>
      <button type="submit">{{ t('auth.reset_password') }}</button>
    </form>
    <p><a href="{{ url_for('accounts.login') }}">{{ t('auth.back_to_login') }}</a></p>
  </div>
</section>
{% endblock %}
