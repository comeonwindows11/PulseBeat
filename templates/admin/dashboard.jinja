{% extends "admin/base.jinja" %}
{% block title %}{{ t('nav.admin') }} - {{ app_name }}{% endblock %}

{% block content %}
{% if password_check_status and password_check_status.status == "down" %}
<div class="card alert-card">
  <h3>{{ t('admin.security_alert') }}</h3>
  <p>{{ t('admin.password_check_down') }}</p>
  <p class="muted small">{{ password_check_status.message }}</p>
</div>
{% endif %}

{% if moderation_status and moderation_status.status == "alert" %}
<div class="card alert-card">
  <h3>{{ t('admin.moderation_alert') }}</h3>
  <p>{{ moderation_status.message }}</p>
  <p class="muted small">{{ moderation_status.updated_at }}</p>
</div>
{% endif %}

<section class="grid two-cols">
  <div class="card">
    <h2>{{ t('admin.create_admin') }}</h2>
    <form method="post" action="{{ url_for('admin.create_admin') }}" class="stack" data-validate-form="1">
      <label>{{ t('auth.username') }}
        <input type="text" id="admin-create-username" name="username" minlength="3" maxlength="32" pattern="[A-Za-z0-9_.-]{3,32}" data-remote-check="username" data-remote-url="{{ url_for('accounts.check_availability') }}" required>
      </label>
      <label>{{ t('auth.email') }}
        <input type="email" id="admin-create-email" name="email" data-remote-check="email" data-remote-url="{{ url_for('accounts.check_availability') }}" required>
      </label>
      <label>{{ t('auth.password') }}
        <input type="password" id="admin-create-password" name="password" minlength="6" data-password-policy="1" required>
      </label>
      <p class="muted small">{{ t('auth.password_policy') }}</p>
      <label>{{ t('account.confirm_password') }}
        <input type="password" name="confirm_password" minlength="6" data-match-target="admin-create-password" required>
      </label>
      <button type="submit">{{ t('admin.create_admin') }}</button>
    </form>
  </div>

  <div class="card">
    <h2>{{ t('admin.users') }}</h2>
    <ul class="playlist-list users-scroll">
      {% for user in users %}
        <li>
          <div>
            <strong>{{ user.username }}</strong> ({{ user.email }}) {% if user.is_root_admin %}[root admin]{% elif user.is_admin %}[admin]{% endif %}
            {% if user.banned_until and user.banned_until > now %}
              <p class="muted small">{{ t('admin.banned_until') }}: {{ user.banned_until }}</p>
            {% endif %}
          </div>
          <div class="row-actions">
            {% if not user.is_root_admin %}
            <form method="post" action="{{ url_for('admin.ban_user', user_id=user._id|string) }}" class="row-actions">
              <select name="days">
                <option value="1">1d</option>
                <option value="7">7d</option>
                <option value="30">30d</option>
              </select>
              <button type="submit" class="btn secondary">{{ t('admin.ban') }}</button>
            </form>
            <form method="post" action="{{ url_for('admin.unban_user', user_id=user._id|string) }}">
              <button type="submit" class="btn secondary">{{ t('admin.unban') }}</button>
            </form>
            {% endif %}
            {% if (not user.is_root_admin) and (not user.is_admin or me.is_root_admin) %}
            <form method="post" action="{{ url_for('admin.delete_user', user_id=user._id|string) }}" class="row-actions">
              <select name="delete_songs">
                <option value="yes">{{ t('yes') }}</option>
                <option value="no">{{ t('no') }}</option>
              </select>
              <button type="submit" class="btn-danger">{{ t('admin.delete_user') }}</button>
            </form>
            {% endif %}
          </div>
        </li>
      {% endfor %}
    </ul>
    <div class="pagination">
      {% if users_page > 1 %}
        <a class="btn secondary" href="{{ url_for('admin.dashboard', users_page=users_page-1, songs_page=songs_page, comments_page=comments_page, reports_page=reports_page, logs_page=logs_page) }}">{{ t('main.prev') }}</a>
      {% endif %}
      <span>{{ t('main.page', page=users_page, pages=users_pages) }}</span>
      {% if users_page < users_pages %}
        <a class="btn secondary" href="{{ url_for('admin.dashboard', users_page=users_page+1, songs_page=songs_page, comments_page=comments_page, reports_page=reports_page, logs_page=logs_page) }}">{{ t('main.next') }}</a>
      {% endif %}
    </div>
  </div>

  <div class="card">
    <h2>{{ t('admin.songs') }}</h2>
    <ul class="playlist-list users-scroll">
      {% for song in songs %}
        <li>
          <span>{{ song.title }} - {{ song.artist }}</span>
          <form method="post" action="{{ url_for('songs.admin_delete_song', song_id=song._id|string) }}">
            <button type="submit" class="btn-danger">{{ t('main.delete') }}</button>
          </form>
        </li>
      {% endfor %}
    </ul>
    <div class="pagination">
      {% if songs_page > 1 %}
        <a class="btn secondary" href="{{ url_for('admin.dashboard', users_page=users_page, songs_page=songs_page-1, comments_page=comments_page, reports_page=reports_page, logs_page=logs_page) }}">{{ t('main.prev') }}</a>
      {% endif %}
      <span>{{ t('main.page', page=songs_page, pages=songs_pages) }}</span>
      {% if songs_page < songs_pages %}
        <a class="btn secondary" href="{{ url_for('admin.dashboard', users_page=users_page, songs_page=songs_page+1, comments_page=comments_page, reports_page=reports_page, logs_page=logs_page) }}">{{ t('main.next') }}</a>
      {% endif %}
    </div>
  </div>

  
  <div class="card">
    <h2>{{ t('admin.comments') }}</h2>
    <ul class="playlist-list users-scroll">
      {% for comment in comments %}
        <li>
          <span>{{ comment.content }}</span>
          <form method="post" action="{{ url_for('admin.delete_comment', comment_id=comment._id|string) }}">
            <button type="submit" class="btn-danger">{{ t('main.delete') }}</button>
          </form>
        </li>
      {% endfor %}
    </ul>
    <div class="pagination">
      {% if comments_page > 1 %}
        <a class="btn secondary" href="{{ url_for('admin.dashboard', users_page=users_page, songs_page=songs_page, comments_page=comments_page-1, reports_page=reports_page, logs_page=logs_page) }}">{{ t('main.prev') }}</a>
      {% endif %}
      <span>{{ t('main.page', page=comments_page, pages=comments_pages) }}</span>
      {% if comments_page < comments_pages %}
        <a class="btn secondary" href="{{ url_for('admin.dashboard', users_page=users_page, songs_page=songs_page, comments_page=comments_page+1, reports_page=reports_page, logs_page=logs_page) }}">{{ t('main.next') }}</a>
      {% endif %}
    </div>
  </div>

  <div class="card">
    <h2>{{ t('admin.reports') }}</h2>
    <ul class="playlist-list users-scroll">
      {% for report in reports %}
        <li>
          <div>
            <strong>{{ report.target_type }}</strong>
            <p>{{ report.reason }}</p>
            <p class="muted small">{{ report.status }}</p>
          </div>
          <div class="row-actions">
            <form method="post" action="{{ url_for('admin.resolve_report', report_id=report._id|string) }}" class="row-actions">
              <select name="action">
                <option value="resolve_only">{{ t('admin.resolve') }}</option>
                <option value="delete_song">{{ t('admin.resolve_delete_song') }}</option>
                <option value="delete_comment">{{ t('admin.resolve_delete_comment') }}</option>
              </select>
              <button type="submit" class="btn secondary">{{ t('admin.resolve') }}</button>
            </form>
            <form method="post" action="{{ url_for('admin.dismiss_report', report_id=report._id|string) }}">
              <button type="submit" class="btn secondary">{{ t('admin.dismiss') }}</button>
            </form>
          </div>
        </li>
      {% endfor %}
    </ul>
    <div class="pagination">
      {% if reports_page > 1 %}
        <a class="btn secondary" href="{{ url_for('admin.dashboard', users_page=users_page, songs_page=songs_page, comments_page=comments_page, reports_page=reports_page-1, logs_page=logs_page) }}">{{ t('main.prev') }}</a>
      {% endif %}
      <span>{{ t('main.page', page=reports_page, pages=reports_pages) }}</span>
      {% if reports_page < reports_pages %}
        <a class="btn secondary" href="{{ url_for('admin.dashboard', users_page=users_page, songs_page=songs_page, comments_page=comments_page, reports_page=reports_page+1, logs_page=logs_page) }}">{{ t('main.next') }}</a>
      {% endif %}
    </div>
  </div>

  <div class="card">
    <h2>{{ t('admin.audit_logs') }}</h2>
    <ul class="playlist-list users-scroll">
      {% for log in audit_logs %}
        <li>
          <div>
            <strong>{{ log.action }}</strong>
            <p class="muted small">{{ log.target_type }} {{ log.target_id }}</p>
          </div>
          <span class="muted small">{{ log.created_at }}</span>
        </li>
      {% endfor %}
    </ul>
    <div class="pagination">
      {% if logs_page > 1 %}
        <a class="btn secondary" href="{{ url_for('admin.dashboard', users_page=users_page, songs_page=songs_page, comments_page=comments_page, reports_page=reports_page, logs_page=logs_page-1) }}">{{ t('main.prev') }}</a>
      {% endif %}
      <span>{{ t('main.page', page=logs_page, pages=logs_pages) }}</span>
      {% if logs_page < logs_pages %}
        <a class="btn secondary" href="{{ url_for('admin.dashboard', users_page=users_page, songs_page=songs_page, comments_page=comments_page, reports_page=reports_page, logs_page=logs_page+1) }}">{{ t('main.next') }}</a>
      {% endif %}
    
    </div>
  </div>
  </section>
{% endblock %}


