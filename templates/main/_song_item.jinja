<li data-song-id="{{ song.id }}" data-created-ts="{{ song.created_ts|default(0) }}" class="{% if not song.is_available %}song-unavailable{% endif %}">
  <div>
    <a href="{{ song.detail_url }}"><strong>{{ song.title }}</strong></a>
    <p>{{ song.artist }}{% if song.genre %} - {{ song.genre }}{% endif %}</p>
    <span class="badge">{{ t('main.visibility.' ~ song.visibility) }}</span>
    {% if not song.is_available %}
      <span class="badge">{{ t('song.unavailable') }}</span>
    {% endif %}
    {% if song.visibility == "private" %}
      <span class="muted small">{{ t('main.shared_count', count=song.shared_count) }}</span>
    {% endif %}
  </div>
  <div class="row-actions">
    <button
      type="button"
      class="play-one"
      data-context="auto"
      data-song='{{ {"id": song.id, "title": song.title, "artist": song.artist, "url": song.url, "detail_url": song.detail_url, "source_type": song.source_type, "source_url": song.source_url, "external_provider": song.external_provider, "youtube_video_id": song.youtube_video_id, "playback_mode": song.playback_mode, "is_available": song.is_available, "is_audio_playable": song.is_audio_playable}|tojson|safe }}'
    >{{ t('main.play') }}</button>
    <a class="btn secondary" href="{{ song.detail_url }}">{{ t('song.details') }}</a>
    {% if song.can_delete %}
      <form method="post" action="{{ url_for('songs.delete_song', song_id=song.id) }}" class="delete-song-form">
        <button type="submit" class="btn-danger">{{ t('main.delete') }}</button>
      </form>
    {% endif %}
  </div>
</li>
