{% extends "layout/base.jinja" %}
{% block title %}{{ t('auth.forgot_password') }} - {{ app_name }}{% endblock %}

{% block content %}
<section class="auth-wrap">
  <div class="card auth-card">
    <h1>{{ t('auth.password_recovery_title') }}</h1>
    <p class="muted">{{ t('auth.password_recovery_help') }}</p>

    <div class="stack top-gap">
      {% for method in methods %}
      <form method="post" class="sub-card stack compact-stack">
        <input type="hidden" name="method" value="{{ method }}">
        <div class="row-actions">
          <div>
            <strong>{{ method_labels.get(method, method) }}</strong>
            {% if method == 'primary_email' %}
            <p class="muted small">{{ t('auth.password_recovery_primary_email', email=masked_primary_email) }}</p>
            {% elif method == 'backup_email' %}
            <p class="muted small">{{ t('auth.password_recovery_backup_email', email=masked_backup_email) }}</p>
            {% elif method == '2fa_email' %}
            <p class="muted small">{{ t('auth.password_recovery_email_2fa') }}</p>
            {% elif method == '2fa_totp' %}
            <p class="muted small">{{ t('auth.password_recovery_totp') }}</p>
            {% endif %}
          </div>
          {% if method != selected_method %}
          <button type="submit" name="action" value="switch" class="btn secondary">{{ t('auth.password_recovery_choose_method') }}</button>
          {% endif %}
        </div>

        {% if method == selected_method %}
          {% if method in ['primary_email', 'backup_email'] %}
          <button type="submit" name="action" value="send_link">{{ t('auth.send_reset_link') }}</button>
          {% else %}
          <label>
            {% if method == '2fa_totp' %}
              {{ t('auth.two_factor_authenticator_code_label') }}
            {% else %}
              {{ t('auth.two_factor_code_label') }}
            {% endif %}
            <input type="text" name="code" inputmode="numeric" pattern="[0-9]{6}" minlength="6" maxlength="6" required>
          </label>
          <div class="row-actions">
            <button type="submit" name="action" value="verify">{{ t('auth.two_factor_verify') }}</button>
            {% if method == '2fa_email' %}
            <button type="submit" name="action" value="resend" class="btn secondary">{{ t('auth.two_factor_resend') }}</button>
            {% endif %}
          </div>
          {% if method == '2fa_email' %}
          <p class="muted small">{{ t('auth.two_factor_challenge_expiry', minutes=expires_minutes) }}</p>
          {% endif %}
          {% endif %}
        {% endif %}
      </form>
      {% endfor %}
    </div>

    <p class="top-gap"><a href="{{ url_for('accounts.forgot_password') }}">{{ t('auth.back_to_login') }}</a></p>
  </div>
</section>
{% endblock %}
