{% extends "layout/base.jinja" %}
{% block title %}{{ t('nav.my_songs') }} - {{ app_name }}{% endblock %}

{% block content %}
<section class="card">
  <h1>{{ t('nav.my_songs') }}</h1>
  {% if songs %}
    <ul class="song-list">
      {% for song in songs %}
        <li>
          <div>
            <a href="{{ song.detail_url }}"><strong>{{ song.title }}</strong></a>
            <p>{{ song.artist }}</p>
            <span class="badge">{{ t('main.visibility.' ~ song.visibility) }}</span>
          </div>
          <div class="row-actions">
            <button type="button" class="play-one" data-song='{{ {"id": song.id, "title": song.title, "artist": song.artist, "url": song.url}|tojson|safe }}'>{{ t('main.play') }}</button>
            <a class="btn secondary" href="{{ song.detail_url }}">{{ t('song.details') }}</a>
            <form method="post" action="{{ url_for('songs.delete_song', song_id=song.id) }}" class="delete-song-form">
              <button type="submit" class="btn-danger">{{ t('main.delete') }}</button>
            </form>
          </div>
        </li>
      {% endfor %}
    </ul>
    <div class="pagination">
      {% if page > 1 %}
        <a class="btn secondary" href="{{ url_for('songs.my_songs', page=page-1) }}">{{ t('main.prev') }}</a>
      {% endif %}
      <span>{{ t('main.page', page=page, pages=pages) }}</span>
      {% if page < pages %}
        <a class="btn secondary" href="{{ url_for('songs.my_songs', page=page+1) }}">{{ t('main.next') }}</a>
      {% endif %}
    </div>
  {% else %}
    <p>{{ t('song.none_mine') }}</p>
  {% endif %}
</section>

<script>
  window.PAGE_SONG_OBJECTS = [
  {% for song in songs %}
    {{ {"id": song.id, "title": song.title, "artist": song.artist, "url": song.url}|tojson|safe }}{% if not loop.last %},{% endif %}
  {% endfor %}
  ];
</script>
{% endblock %}
