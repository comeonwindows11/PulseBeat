{% extends "layout/base.jinja" %}
{% block title %}{{ t('account.two_factor_title') }} - {{ app_name }}{% endblock %}

{% block content %}
<section class="auth-card two-factor-card">
  <h1>{{ t('account.two_factor_title') }}</h1>
  {% if selected_method == "totp" %}
  <p class="muted">{{ t('auth.two_factor_authenticator_intro') }}</p>
  {% else %}
  <p class="muted">{{ t('auth.two_factor_challenge_intro') }}</p>
  <p class="muted small">{{ t('auth.two_factor_challenge_sent_to', email=masked_email) }}</p>
  <p class="muted small">{{ t('auth.two_factor_challenge_expiry', minutes=expires_minutes) }}</p>
  {% endif %}

  <div class="badge-row top-gap">
    <span class="badge">{{ t('account.two_factor_method_' ~ selected_method) }}</span>
    {% if alternate_method %}
    <span class="badge">{{ t('account.two_factor_alt_available', method=t('account.two_factor_method_' ~ alternate_method)) }}</span>
    {% endif %}
  </div>

  <form method="post" class="stack top-gap" data-validate-form="1">
    <label>
      {% if selected_method == "totp" %}
        {{ t('auth.two_factor_authenticator_code_label') }}
      {% else %}
        {{ t('auth.two_factor_code_label') }}
      {% endif %}
      <input
        type="text"
        name="code"
        inputmode="numeric"
        autocomplete="one-time-code"
        pattern="[0-9]{6}"
        minlength="6"
        maxlength="6"
        required
      >
    </label>
    <div class="row-actions">
      <button type="submit" name="action" value="verify">{{ t('auth.two_factor_verify') }}</button>
      {% if selected_method == "email" %}
      <button type="submit" name="action" value="resend" class="btn secondary">{{ t('auth.two_factor_resend') }}</button>
      {% endif %}
      {% if alternate_method %}
      <button type="submit" name="action" value="switch" class="btn secondary">{{ t('auth.two_factor_switch_to', method=t('account.two_factor_method_' ~ alternate_method)) }}</button>
      <input type="hidden" name="method" value="{{ alternate_method }}">
      {% endif %}
      <a class="btn secondary" href="{{ url_for('accounts.login') }}">{{ t('auth.back_to_login') }}</a>
    </div>
  </form>
</section>
{% endblock %}
