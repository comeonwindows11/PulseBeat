{% extends "layout/base.jinja" %}
{% block title %}{{ t('nav.home') }} - {{ app_name }}{% endblock %}

{% block content %}
<section class="grid two-cols">
  <div class="card">
    <h1>{{ t('main.title') }}</h1>
    <form method="get" action="{{ url_for('main.index') }}" class="search-form">
      <input type="text" name="q" placeholder="{{ t('main.search_placeholder') }}" value="{{ q }}" data-autocomplete-url="{{ url_for('songs.search_suggest') }}" autocomplete="off">
      <select name="sort">
        <option value="date" {% if sort == "date" %}selected{% endif %}>{{ t('main.sort.date') }}</option>
        <option value="title" {% if sort == "title" %}selected{% endif %}>{{ t('main.sort.title') }}</option>
        <option value="artist" {% if sort == "artist" %}selected{% endif %}>{{ t('main.sort.artist') }}</option>
      </select>
      <button type="submit">{{ t('main.apply') }}</button>
    </form>
    <p class="muted small">{{ t('main.results', count=total) }}</p>

    {% if songs %}
      <ul class="song-list">
        {% for song in songs %}
          <li>
            <div>
              <a href="{{ song.detail_url }}"><strong>{{ song.title }}</strong></a>
              <p>{{ song.artist }}{% if song.genre %} - {{ song.genre }}{% endif %}</p>
              <span class="badge">{{ t('main.visibility.' ~ song.visibility) }}</span>
              {% if song.visibility == "private" %}
                <span class="muted small">{{ t('main.shared_count', count=song.shared_count) }}</span>
              {% endif %}
            </div>
            <div class="row-actions">
              <button
                type="button"
                class="play-one"
                data-context="auto"
                data-song='{{ {"id": song.id, "title": song.title, "artist": song.artist, "url": song.url, "detail_url": song.detail_url}|tojson|safe }}'
              >{{ t('main.play') }}</button>
              <a class="btn secondary" href="{{ song.detail_url }}">{{ t('song.details') }}</a>
              <button type="button" class="queue-all" data-source="all" data-context="auto">{{ t('main.queue_all') }}</button>
              {% if song.can_delete %}
                <form method="post" action="{{ url_for('songs.delete_song', song_id=song.id) }}" class="delete-song-form">
                  <button type="submit" class="btn-danger">{{ t('main.delete') }}</button>
                </form>
              {% endif %}
            </div>
          </li>
        {% endfor %}
      </ul>
      <div class="pagination">
        {% if page > 1 %}
          <a class="btn secondary" href="{{ url_for('main.index', q=q, sort=sort, page=page-1) }}">{{ t('main.prev') }}</a>
        {% endif %}
        <span>{{ t('main.page', page=page, pages=pages) }}</span>
        {% if page < pages %}
          <a class="btn secondary" href="{{ url_for('main.index', q=q, sort=sort, page=page+1) }}">{{ t('main.next') }}</a>
        {% endif %}
      </div>
    {% else %}
      <p>{{ t('main.no_songs') }}</p>
    {% endif %}
  </div>

  <div class="card">
    <h2>{{ t('main.recommended') }}</h2>
    {% if recommended_songs %}
      <ul class="song-list">
        {% for song in recommended_songs %}
          <li>
            <div>
              <a href="{{ song.detail_url }}"><strong>{{ song.title }}</strong></a>
              <p>{{ song.artist }}{% if song.genre %} - {{ song.genre }}{% endif %}</p>
            </div>
            <div class="row-actions">
              <button
                type="button"
                class="play-one"
                data-context="auto"
                data-song='{{ {"id": song.id, "title": song.title, "artist": song.artist, "url": song.url, "detail_url": song.detail_url}|tojson|safe }}'
              >{{ t('main.play') }}</button>
              <a class="btn secondary" href="{{ song.detail_url }}">{{ t('song.details') }}</a>
            </div>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <p>{{ t('main.no_recommendations') }}</p>
    {% endif %}
  </div>

  {% if current_user %}
  <div class="card">
    <h2>{{ t('main.add_song') }}</h2>
    <form method="post" action="{{ url_for('songs.add_song') }}" enctype="multipart/form-data" class="stack" id="add-song-form">
      <label>{{ t('main.field.title') }}
        <input type="text" name="title" id="song-title-input" required>
      </label>
      <label>{{ t('main.field.artist') }}
        <input type="text" name="artist" id="song-artist-input">
      </label>
      <label>{{ t('main.field.genre') }}
        <input type="text" name="genre" id="song-genre-input">
      </label>
      <label>{{ t('main.field.url') }}
        <input type="url" name="song_url" placeholder="https://.../audio.mp3">
      </label>
      <label>{{ t('main.field.file') }}
        <input type="file" name="song_file" id="song-file-input" accept=".mp3,.wav,.ogg,.m4a">
        <span id="id3-status" class="muted small"></span>
      </label>
      <label>{{ t('main.field.visibility') }}
        <select name="visibility" id="visibility-select">
          <option value="public">{{ t('main.visibility.public') }}</option>
          <option value="private">{{ t('main.visibility.private') }}</option>
          <option value="unlisted">{{ t('main.visibility.unlisted') }}</option>
        </select>
      </label>

      <div id="shared-with-wrap" class="hidden stack">
        <button
          type="button"
          class="btn secondary open-user-picker"
          data-target-inputs="song-shared-inputs"
          data-target-list="song-shared-list"
          data-picker-title="{{ t('main.share_with') }}" data-input-name="shared_with"
        >{{ t('main.share_with_add') }}</button>
        <div id="song-shared-list" class="selected-users"></div>
        <div id="song-shared-inputs"></div>
      </div>

      <button type="submit" id="add-song-submit">{{ t('main.add') }}</button>
    </form>
  </div>
  {% else %}
  <div class="card">
    <h2>{{ t('main.start') }}</h2>
    <p>{{ t('main.start_desc') }}</p>
    <div class="row-actions">
      <a class="btn" href="{{ url_for('accounts.register') }}">{{ t('nav.register') }}</a>
      <a class="btn secondary" href="{{ url_for('accounts.login') }}">{{ t('nav.login') }}</a>
    </div>
  </div>
  {% endif %}
</section>

<script>
  window.PAGE_SONG_OBJECTS = [
  {% for song in songs %}
    {{ {"id": song.id, "title": song.title, "artist": song.artist, "url": song.url, "detail_url": song.detail_url}|tojson|safe }}{% if not loop.last %},{% endif %}
  {% endfor %}
  ];
  window.PAGE_RECOMMENDED_SONGS = [
  {% for song in recommended_songs %}
    {{ {"id": song.id, "title": song.title, "artist": song.artist, "url": song.url, "detail_url": song.detail_url}|tojson|safe }}{% if not loop.last %},{% endif %}
  {% endfor %}
  ];
</script>
{% endblock %}

