{% extends "layout/base.jinja" %}
{% block title %}{{ t('license.title') }} - {{ app_name }}{% endblock %}
{% block content %}
<section class="hero hero-compact">
  <div class="hero-copy stack">
    <p class="hero-kicker">{{ app_name }}</p>
    <h1>{{ t('license.heading') }}</h1>
    <p class="muted">{{ t('license.subtitle') }}</p>
  </div>
</section>

<section class="card stack">
  <pre class="license-text">{{ license_text }}</pre>
</section>
{% endblock %}
