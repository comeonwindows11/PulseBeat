{% extends "layout/base.jinja" %}
{% block title %}{{ t('setup.title') }} - {{ app_name }}{% endblock %}

{% block content %}
<div class="modal setup-modal-force" aria-hidden="false">
  <div class="modal-card setup-card">
    <h1>{{ t('setup.title') }}</h1>
    <p>{{ t('setup.subtitle') }}</p>

    <form method="post" action="{{ url_for('accounts.setup_admin') }}" class="stack">
      <label>{{ t('auth.username') }}
        <input type="text" name="username" required>
      </label>
      <label>{{ t('auth.email') }}
        <input type="email" name="email" required>
      </label>
      <p class="muted small">{{ t('auth.verification_email_sent_note') }}</p>
      <label>{{ t('auth.password') }}
        <input type="password" name="password" minlength="6" required>
      </label>
      <p class="muted small">{{ t('auth.password_policy') }}</p>
      <label>{{ t('account.confirm_password') }}
        <input type="password" name="confirm_password" minlength="6" required>
      </label>
      <button type="submit">{{ t('setup.create_root_admin') }}</button>
    </form>
  </div>
</div>
{% endblock %}
