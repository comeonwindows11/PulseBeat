<!doctype html>
<html lang="{{ current_lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}{{ app_name }}{% endblock %}</title>
  <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
  <noscript>
    <style>
      html, body {
        height: 100%;
        overflow: hidden !important;
      }
      header,
      main,
      .player-shell,
      .modal,
      .player-bottom-sheet {
        display: none !important;
      }
      .nojs-blocker {
        position: fixed !important;
        inset: 0 !important;
        z-index: 2147483647 !important;
        display: grid !important;
        place-items: center !important;
        padding: 18px !important;
        background: rgba(0, 0, 0, 0.92) !important;
      }
      .nojs-blocker__card {
        width: min(96vw, 620px);
        padding: 22px;
        border: 1px solid #4567a7;
        border-radius: 16px;
        background: linear-gradient(180deg, #111c33, #1a2947);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
        color: #ecf2ff;
      }
      .nojs-blocker__card h1 {
        margin-top: 0;
      }
      .nojs-blocker__card p {
        margin-bottom: 0;
        line-height: 1.6;
      }
    </style>
    <div class="nojs-blocker" aria-hidden="false" role="dialog" aria-modal="true">
      <div class="nojs-blocker__card">
        <h1>{{ t('nojs.title') }}</h1>
        <p>{{ t('nojs.body') }}</p>
      </div>
    </div>
  </noscript>
  <header class="topbar">
    <a href="{% if current_user and current_user.require_password_change %}{{ url_for('accounts.manage_account') }}{% elif current_user %}{{ url_for('main.index') }}{% else %}{{ url_for('accounts.login') }}{% endif %}" class="logo">{{ app_name }}</a>
    <button id="menu-toggle" class="menu-toggle" type="button" aria-label="{{ t('lang.switch') }}" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <form method="post" action="{{ url_for('main.set_language') }}" class="lang-form">
      <input type="hidden" name="next" value="{{ request.full_path }}">
      <label for="lang-select" class="small muted">{{ t('lang.switch') }}</label>
      <select id="lang-select" name="lang" onchange="this.form.submit()">
        <option value="fr" {% if current_lang == "fr" %}selected{% endif %}>{{ t('lang.fr') }}</option>
        <option value="en" {% if current_lang == "en" %}selected{% endif %}>{{ t('lang.en') }}</option>
      </select>
    </form>
    <nav id="main-nav" class="main-nav">
      {% if current_user %}
        {% if current_user.require_password_change %}
          <a href="{{ url_for('accounts.manage_account') }}">{{ t('nav.manage_account') }}</a>
        {% else %}
          <a href="{{ url_for('main.index') }}">{{ t('nav.home') }}</a>
          <a href="{{ url_for('songs.my_songs') }}">{{ t('nav.my_songs') }}</a>
          <a href="{{ url_for('songs.new_song') }}">{{ t('main.add_song') }}</a>
          <a href="{{ url_for('playlists.list_playlists') }}">{{ t('nav.playlists') }}</a>
          <a href="{{ url_for('accounts.listening_history') }}">{{ t('nav.history') }}</a>
          <a href="{{ url_for('accounts.manage_account') }}">{{ t('nav.manage_account') }}</a>
          <div class="notification-menu">
            <button
              id="notifications-toggle"
              class="nav-icon-btn"
              type="button"
              aria-label="{{ t('notifications.title') }}"
              aria-expanded="false"
              data-mark-read-url="{{ url_for('accounts.mark_all_notifications_read') }}"
            >
              <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 22a2.5 2.5 0 0 0 2.45-2h-4.9A2.5 2.5 0 0 0 12 22zm6-6V11a6 6 0 1 0-12 0v5l-2 2v1h16v-1l-2-2z"></path>
              </svg>
              {% if header_notifications_unread %}
              <span id="notifications-badge" class="notification-badge">{{ "99+" if header_notifications_unread > 99 else header_notifications_unread }}</span>
              {% else %}
              <span id="notifications-badge" class="notification-badge hidden">0</span>
              {% endif %}
            </button>
            <div id="notifications-panel" class="notifications-panel hidden" aria-hidden="true">
              <div class="notifications-panel-head">
                <strong>{{ t('notifications.title') }}</strong>
                <button id="notifications-close" type="button" class="btn secondary notifications-close-btn">{{ t('modal.close') }}</button>
              </div>
              {% if header_notifications %}
              <ul class="notifications-list">
                {% for item in header_notifications %}
                <li class="notification-item{% if not item.is_read %} unread{% endif %}">
                  <p class="small muted">{{ item.created_at.strftime('%Y-%m-%d %H:%M') if item.created_at else '' }}</p>
                  <p class="notification-item-body">
                    {% if item.creator_url %}
                    <a href="{{ item.creator_url }}">{{ item.creator_username }}</a>
                    {% else %}
                    <strong>{{ item.creator_username }}</strong>
                    {% endif %}
                    {% if item.content_type == "playlist" %}
                    {{ t('notifications.publication_playlist') }}
                    {% else %}
                    {{ t('notifications.publication_song') }}
                    {% endif %}
                    {% if item.content_url %}
                    <a href="{{ item.content_url }}">{{ item.content_title }}</a>
                    {% else %}
                    <strong>{{ item.content_title }}</strong>
                    {% endif %}
                  </p>
                </li>
                {% endfor %}
              </ul>
              {% else %}
              <p class="muted small notifications-empty">{{ t('notifications.empty') }}</p>
              {% endif %}
            </div>
          </div>
          {% if current_user.is_admin %}
            <a href="{{ url_for('admin.dashboard') }}">{{ t('nav.admin') }}</a>
          {% endif %}
          <a href="{{ url_for('accounts.logout') }}">{{ t('nav.logout') }}</a>
        {% endif %}
      {% else %}
        <a href="{{ url_for('accounts.login') }}">{{ t('nav.login') }}</a>
        <a href="{{ url_for('accounts.register') }}">{{ t('nav.register') }}</a>
      {% endif %}
    </nav>
  </header>

  <main class="page-container">
    {% with messages = get_flashed_messages(with_categories=true) %}
      {% if messages %}
        <div class="flash-list server-flash-list">
          {% for category, message in messages %}
            <div class="flash {{ category }}">{{ message }}</div>
          {% endfor %}
        </div>
      {% endif %}
    {% endwith %}

    {% block content %}{% endblock %}
  </main>

  <div id="confirm-modal" class="modal hidden" aria-hidden="true" role="dialog" aria-modal="true">
    <div class="modal-card">
      <h3>{{ t('modal.delete.title') }}</h3>
      <p>{{ t('modal.delete.body') }}</p>
      <div class="row-actions">
        <button id="modal-cancel" type="button" class="btn secondary">{{ t('modal.cancel') }}</button>
        <button id="modal-confirm" type="button" class="btn-danger">{{ t('modal.delete') }}</button>
      </div>
    </div>
  </div>

  <div id="report-modal" class="modal hidden" aria-hidden="true" role="dialog" aria-modal="true">
    <div class="modal-card">
      <h3 id="report-modal-title">{{ t('song.report') }}</h3>
      <form id="report-modal-form" method="post" class="stack">
        <label>{{ t('song.report_reason') }}
          <textarea name="reason" id="report-modal-reason" required rows="4"></textarea>
        </label>
        <div class="row-actions">
          <button type="button" id="report-modal-cancel" class="btn secondary">{{ t('modal.cancel') }}</button>
          <button type="submit" class="btn-danger">{{ t('song.report') }}</button>
        </div>
      </form>
    </div>
  </div>

  <div id="lyrics-candidate-modal" class="modal hidden" aria-hidden="true" role="dialog" aria-modal="true">
    <div class="modal-card modal-card-wide">
      <h3 id="lyrics-candidate-title">{{ t('song.lyrics_candidate_title') }}</h3>
      <p id="lyrics-candidate-meta" class="muted small"></p>
      <pre id="lyrics-candidate-preview" class="lyrics-preview-box"></pre>
      <div class="row-actions">
        <button type="button" id="lyrics-candidate-reject" class="btn secondary">{{ t('song.lyrics_candidate_wrong') }}</button>
        <button type="button" id="lyrics-candidate-accept" class="btn">{{ t('song.lyrics_use_candidate') }}</button>
      </div>
    </div>
  </div>

  <div id="lyrics-loading-modal" class="modal hidden" aria-hidden="true" role="dialog" aria-modal="true">
    <div class="modal-card">
      <h3>{{ t('song.lyrics_loading_title') }}</h3>
      <p id="lyrics-loading-step" class="muted small">{{ t('song.lyrics_loading_step_metadata') }}</p>
    </div>
  </div>

  <div id="user-picker-modal" class="modal hidden" aria-hidden="true" role="dialog" aria-modal="true">
    <div class="modal-card">
      <h3 id="user-picker-title">{{ t('main.share_with') }}</h3>
      <div class="stack">
        <input type="text" id="user-picker-search" autocomplete="off" placeholder="{{ t('search.user_placeholder') }}" data-autocomplete-url="{{ url_for('accounts.users_suggest') }}">
        <div id="user-picker-suggestions" class="autocomplete-box"></div>
        <div id="user-picker-selected" class="selected-users"></div>
        <div class="row-actions">
          <button type="button" id="user-picker-cancel" class="btn secondary">{{ t('modal.cancel') }}</button>
          <button type="button" id="user-picker-apply" class="btn">{{ t('modal.apply') }}</button>
        </div>
      </div>
    </div>
  </div>

  <div class="player-shell player-shell-hidden" aria-hidden="true">
    <div id="youtube-player-host" class="youtube-player-host" aria-hidden="true"></div>
    <audio id="global-audio" preload="metadata"></audio>
    <div id="player-error-banner" class="player-error-banner hidden" role="status" aria-live="polite">
      <span id="player-error-text"></span>
    </div>
    <div class="player-bar">
      <div class="song-meta">
        <a id="player-title-link" href="#" class="player-title-link">
          <strong id="player-title">{{ t('player.none') }}</strong>
        </a>
        <span id="player-artist">-</span>
        <span id="player-view-status" class="player-view-status muted small">{{ t('player.view.normal') }}</span>
      </div>
      <div class="controls">
        <button id="prev-btn" type="button" aria-label="{{ t('player.previous') }}">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6 6h2v12H6zM9 12l9 6V6z"></path>
          </svg>
        </button>
        <button id="play-pause-btn" class="primary-control" type="button" aria-label="{{ t('player.play') }}" data-state="paused">
          <svg class="icon icon-play" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M8 5v14l11-7z"></path>
          </svg>
          <svg class="icon icon-pause" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M7 5h4v14H7zm6 0h4v14h-4z"></path>
          </svg>
        </button>
        <button id="next-btn" type="button" aria-label="{{ t('player.next') }}">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M16 6h2v12h-2zM6 18l9-6-9-6z"></path>
          </svg>
        </button>
        <button id="player-like-btn" class="player-vote-btn" type="button" aria-label="{{ t('song.like') }}" {% if not current_user %}disabled title="{{ t('song.login_to_react') }}"{% endif %}>
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M2 21h4V9H2v12zM22 10c0-1.1-.9-2-2-2h-6l1-4v-.7c0-.4-.2-.8-.4-1.1L13.6 1 7.7 6.9C7.3 7.3 7 7.8 7 8.4V19c0 1.1.9 2 2 2h8c.8 0 1.5-.5 1.8-1.2l3-7c.1-.2.2-.5.2-.8v-2z"/></svg>
          <span id="player-like-count">0</span>
        </button>
        <button id="player-dislike-btn" class="player-vote-btn" type="button" aria-label="{{ t('song.dislike') }}" {% if not current_user %}disabled title="{{ t('song.login_to_react') }}"{% endif %}>
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M22 3h-4v12h4V3zM2 14c0 1.1.9 2 2 2h6l-1 4v.7c0 .4.2.8.4 1.1l1 1 5.9-5.9c.4-.4.7-.9.7-1.5V5c0-1.1-.9-2-2-2H7c-.8 0-1.5.5-1.8 1.2l-3 7c-.1.2-.2.5-.2.8v2z"/></svg>
          <span id="player-dislike-count">0</span>
        </button>
        {% if not current_user %}
        <span class="player-reaction-auth-hint muted small">{{ t('song.login_to_react') }}</span>
        {% endif %}
        {% if current_user %}
        <button id="player-more-btn" type="button" aria-label="{{ t('player.more') }}" title="{{ t('player.more') }}">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 8a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm0 6a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm0 6a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"></path></svg>
        </button>
        {% endif %}
        {% if current_user %}
        <button id="add-to-playlist-btn" type="button" aria-label="{{ t('player.add_to_playlist') }}">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 10h10v2H3v-2zm0-4h14v2H3V6zm0 8h10v2H3v-2zm16-1v-3h-2v3h-3v2h3v3h2v-3h3v-2h-3z"></path>
          </svg>
        </button>
        {% endif %}
        {% if current_user %}
        <button id="queue-editor-btn" type="button" aria-label="{{ t('player.queue') }}" title="{{ t('player.queue') }}">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 6h14v2H3V6zm0 5h14v2H3v-2zm0 5h10v2H3v-2zm12 0l3-3 3 3h-2v3h-2v-3h-2z"></path>
          </svg>
        </button>
        {% endif %}
        <button id="player-view-btn" class="player-view-btn" type="button" aria-label="{{ t('player.view.normal') }}" data-view-mode="normal" title="{{ t('player.view.normal') }}">
          <svg class="icon view-mini" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 7h16v10H4zM6 9h12v6H6z"></path>
          </svg>
          <svg class="icon view-normal" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 5h18v14H3zM6 8h12v8H6z"></path>
          </svg>
          <svg class="icon view-fullscreen" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M7 3H3v4h2V5h2V3zm14 0h-4v2h2v2h2V3zM5 17H3v4h4v-2H5v-2zm16 0h-2v2h-2v2h4v-4z"></path>
          </svg>
        </button>
        <button id="play-mode-btn" class="mode-btn" type="button" aria-label="{{ t('player.mode.normal') }}" data-mode="normal" title="{{ t('player.mode.normal') }}">
          <svg class="icon mode-normal" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 4h2v16H4zm14 0h2v16h-2zM8 11h8v2H8z"></path>
          </svg>
          <svg class="icon mode-shuffle" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M16 3h5v5h-2V6.41l-4.29 4.3-1.42-1.42L17.59 5H16V3zM4 6h4.59l9.7 9.71L19 15v2h-1.41l-9.7-9.71L7 8H4V6zm9.29 7.29l1.42 1.42-2.59 2.59H8v-2h3.29l2-2.01z"></path>
          </svg>
          <svg class="icon mode-repeat-one" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M7 7h10v3l4-4-4-4v3H7c-2.21 0-4 1.79-4 4v2h2V9c0-1.1.9-2 2-2zm10 10H7v-3l-4 4 4 4v-3h10c2.21 0 4-1.79 4-4v-2h-2v2c0 1.1-.9 2-2 2zm-5-8h-1v6h2v-5h-1z"></path>
          </svg>
        </button>
      </div>
      <div class="progress-wrap">
        <canvas id="waveform" width="600" height="42"></canvas>
        <input id="seek-range" type="range" min="0" max="1000" value="0">
        <div class="progress-meta">
          <span id="time-current">00:00</span>
          <span id="time-remaining">-00:00</span>
          <label class="speed-wrap">{{ t('player.speed') }}
            <select id="speed-select">
              <option value="1">x1</option>
              <option value="1.25">x1.25</option>
              <option value="1.5">x1.5</option>
            </select>
          </label>
        </div>
      </div>
      {% if current_user %}
      <div id="player-lyrics-panel" class="player-lyrics-panel hidden" aria-live="polite">
        <h4>{{ t('player.lyrics') }}</h4>
        <div id="player-lyrics-cues" class="player-lyrics-cues hidden"></div>
        <pre id="player-lyrics-full" class="player-lyrics-full hidden"></pre>
        <p id="player-lyrics-empty" class="muted small hidden">{{ t('player.lyrics_none') }}</p>
      </div>
      {% endif %}
    </div>
  </div>

  {% if current_user %}
  <div id="player-context-menu" class="player-context-menu hidden" role="menu" aria-hidden="true">
    <button id="player-menu-block-song" type="button" role="menuitem"></button>
    <button id="player-menu-block-artist" type="button" role="menuitem"></button>
  </div>

  <div id="player-action-toast" class="player-action-toast hidden" role="status" aria-live="polite">
    <span id="player-action-toast-text"></span>
    <button type="button" id="player-action-toast-undo">{{ t('player.menu.undo') }}</button>
  </div>
  {% endif %}

  <div id="player-playlist-modal" class="player-bottom-sheet hidden" aria-hidden="true" role="dialog" aria-modal="false">
    <div class="sheet-card">
      <div class="row-actions">
        <h3 id="player-playlist-title">{{ t('player.add_to_playlist') }}</h3>
        <button type="button" id="player-playlist-close" class="btn secondary">{{ t('modal.close') }}</button>
      </div>
      <input type="text" id="player-playlist-search" placeholder="{{ t('playlist.search_placeholder') }}" autocomplete="off">
      <button type="button" id="player-open-create-playlist-modal" class="btn secondary">{{ t('playlist.create') }}</button>
      <div id="player-playlist-suggestions" class="autocomplete-box"></div>
      <p id="player-playlist-status" class="muted small" aria-live="polite"></p>
      <div id="player-playlist-toast" class="sheet-toast hidden" role="status" aria-live="polite"></div>
    </div>
  </div>

  <div id="share-modal" class="modal hidden" aria-hidden="true" role="dialog" aria-modal="true">
    <div class="modal-card modal-card-wide share-modal-card">
      <h3 id="share-modal-title">{{ t('share.modal_title') }}</h3>
      <label class="stack">
        <span class="muted small">{{ t('share.link_label') }}</span>
        <input type="text" id="share-link-input" readonly>
      </label>
      <div class="row-actions top-gap">
        <button type="button" id="share-copy-btn" class="btn">{{ t('share.copy_link') }}</button>
        <button type="button" id="share-native-btn" class="btn secondary hidden">{{ t('share.native') }}</button>
        <button type="button" id="share-close-btn" class="btn secondary">{{ t('modal.close') }}</button>
      </div>
      <div class="share-grid top-gap">
        <button type="button" id="share-discord-btn" class="btn secondary">{{ t('share.discord') }}</button>
        <button type="button" id="share-messenger-btn" class="btn secondary">{{ t('share.messenger') }}</button>
        <a id="share-facebook-link" class="btn secondary" href="#" target="_blank" rel="noopener noreferrer">{{ t('share.facebook') }}</a>
        <a id="share-x-link" class="btn secondary" href="#" target="_blank" rel="noopener noreferrer">{{ t('share.x') }}</a>
        <a id="share-telegram-link" class="btn secondary" href="#" target="_blank" rel="noopener noreferrer">{{ t('share.telegram') }}</a>
        <a id="share-whatsapp-link" class="btn secondary" href="#" target="_blank" rel="noopener noreferrer">{{ t('share.whatsapp') }}</a>
        <a id="share-email-link" class="btn secondary" href="#">{{ t('share.email') }}</a>
      </div>
    </div>
  </div>

  <div id="player-create-playlist-modal" class="modal hidden" aria-hidden="true" role="dialog" aria-modal="true">
    <div class="modal-card">
      <h3>{{ t('playlist.create') }}</h3>
      <label>{{ t('playlist.name') }}
        <input type="text" id="player-create-playlist-name" minlength="2" maxlength="120" autocomplete="off" placeholder="{{ t('player.playlist_create_name_placeholder') }}">
      </label>
      <div class="row-actions top-gap">
        <button type="button" id="player-create-playlist-cancel" class="btn secondary">{{ t('modal.cancel') }}</button>
        <button type="button" id="player-create-playlist-confirm" class="btn">{{ t('player.playlist_create_button') }}</button>
      </div>
    </div>
  </div>

  <div id="player-queue-modal" class="modal hidden" aria-hidden="true" role="dialog" aria-modal="true">
    <div class="modal-card modal-card-wide">
      <div class="row-actions">
        <h3>{{ t('player.queue') }}</h3>
        <button type="button" id="queue-editor-close" class="btn secondary">{{ t('modal.close') }}</button>
      </div>
      <p id="player-queue-info" class="muted small"></p>
      <ul id="player-queue-list" class="playlist-list queue-editor-list"></ul>
      <p id="player-queue-empty" class="muted small hidden">{{ t('player.queue_empty') }}</p>
      <div class="row-actions top-gap">
        <button type="button" id="queue-clear-btn" class="btn secondary">{{ t('player.queue_clear') }}</button>
      </div>
      <div class="top-gap stack">
        <label class="row-actions">
          <input type="checkbox" id="queue-crossfade-toggle">
          <span>{{ t('player.crossfade') }}</span>
        </label>
        <label class="row-actions">
          <input type="checkbox" id="queue-normalize-toggle">
          <span>{{ t('player.normalize') }}</span>
        </label>
      </div>
    </div>
  </div>

  <div id="tab-audio-guard-modal" class="modal hidden" aria-hidden="true" role="dialog" aria-modal="true">
    <div class="modal-card tab-guard-card">
      <h3>{{ t('tab_guard.title') }}</h3>
      <p>{{ t('tab_guard.body') }}</p>
      <div class="row-actions">
        <button id="tab-audio-guard-deny" type="button" class="btn secondary">{{ t('tab_guard.keep_old_tab') }}</button>
        <button id="tab-audio-guard-allow" type="button">{{ t('tab_guard.allow_here') }}</button>
      </div>
    </div>
  </div>

  <script>
    window.CSRF_TOKEN = {{ csrf_token|tojson }};
    window.I18N = {
      playerNoSong: {{ t('player.none')|tojson }},
      playerUnknown: {{ t('player.unknown')|tojson }},
      playerUntitled: {{ t('player.untitled')|tojson }},
      playerPlay: {{ t('player.play')|tojson }},
      playerPause: {{ t('player.pause')|tojson }},
