# ============================================================================
# PULSEBEAT - EXEMPLE DE VARIABLES D'ENVIRONNEMENT
# ============================================================================
# Ce fichier liste toutes les variables d'environnement actuellement utilisées
# par PulseBeat.
#
# Organisation :
# 1) Variables obligatoires au fonctionnement de base
# 2) Variables optionnelles (fonctionnalites, securite, performances, debug)
#
# Astuce : copie ce fichier vers `.env`, puis adapte seulement ce dont tu as
# besoin. Les variables non definies gardent en general leur valeur par defaut.
# ============================================================================


# ============================================================================
# 1) OBLIGATOIRE AU FONCTIONNEMENT DE BASE
# ============================================================================
# Sans ces variables, PulseBeat ne doit pas etre considere comme correctement
# configure pour un vrai usage.

# Cle secrete Flask utilisee pour les sessions, tokens et signatures internes.
# Obligatoire : oui.
# IMPORTANT : change-la absolument en production.
FLASK_SECRET_KEY=change-me-in-production

# URI MongoDB principale de PulseBeat.
# Obligatoire : oui.
# Exemple Atlas : mongodb+srv://username:password@cluster.mongodb.net/musicPlayer?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/musicPlayer?retryWrites=true&w=majority


# ============================================================================
# 2) OPTIONNEL - DEPLOIEMENT ET COMPORTEMENT GLOBAL
# ============================================================================
# Ces variables ne sont pas strictement obligatoires pour demarrer, mais elles
# sont souvent recommandees selon ton hebergement.

# Port Flask utilise si tu lances directement `python app.py`.
# Souvent fourni automatiquement par Render / Docker / PaaS.
PORT=5000

# URL publique de base de l'application.
# Recommandee si tu utilises des courriels, OAuth Google, des liens absolus ou
# des confirmations par lien.
APP_BASE_URL=http://127.0.0.1:5000

# Force le cookie de session en mode Secure.
# 1 = cookie HTTPS uniquement
# 0 = autorise HTTP local/dev
SESSION_COOKIE_SECURE=0

# Taille maximale acceptee pour une requete/upload Flask (en octets).
# 25 MiB par defaut.
MAX_CONTENT_LENGTH=26214400

# Duree des sessions persistantes quand "Se souvenir de moi" est coche.
REMEMBER_ME_SESSION_DAYS=30

# 1 = sert les bundles JS obfusques si generes
# 0 = sert les sources JS lisibles
JS_SERVE_OBFUSCATED=1


# ============================================================================
# 2A) OPTIONNEL - COURRIEL / SMTP
# ============================================================================
# Requis seulement si tu veux que PulseBeat puisse envoyer des courriels :
# verification d'adresse, reset mot de passe, 2FA par courriel, alertes admin,
# approbation d'appareil, reset plateforme, etc.

# Active ou desactive completement l'envoi de courriels.
MAIL_ENABLED=1

# Serveur SMTP.
MAIL_HOST=smtp.gmail.com

# Port SMTP.
MAIL_PORT=587

# Identifiants SMTP.
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Chiffrement SMTP.
MAIL_USE_TLS=1
MAIL_USE_SSL=0

# Adresse expediteur affichee par PulseBeat.
MAIL_FROM=PulseBeat <your_email@gmail.com>


# ============================================================================
# 2B) OPTIONNEL - TOKENS ET DUREES DE SECURITE
# ============================================================================
# Ces variables ont des valeurs par defaut internes, donc elles ne sont pas
# obligatoires. En production, il est toutefois fortement recommande de changer
# les salts par defaut.

# Reset mot de passe.
PASSWORD_RESET_TOKEN_MAX_AGE=3600
PASSWORD_RESET_SALT=change-this-reset-salt

# Verification de courriel.
EMAIL_VERIFICATION_TOKEN_MAX_AGE=86400
EMAIL_VERIFICATION_SALT=change-this-email-verification-salt

# 2FA courriel / activation-desactivation 2FA / setup TOTP.
TWO_FACTOR_CODE_MAX_AGE=600
TWO_FACTOR_TOGGLE_TOKEN_MAX_AGE=3600
TWO_FACTOR_TOGGLE_SALT=change-this-two-factor-toggle-salt
TWO_FACTOR_TOTP_PENDING_MAX_AGE=900

# Reset complet de la plateforme (root admin seulement).
PLATFORM_RESET_TOKEN_MAX_AGE=1800
PLATFORM_RESET_SALT=change-this-platform-reset-salt


# ============================================================================
# 2C) OPTIONNEL - SECURITE APPAREIL / SESSION
# ============================================================================
# Utilise pour l'approbation des nouveaux appareils et la protection anti-vol
# de session.

DEVICE_COOKIE_NAME=pulsebeat_device_id
DEVICE_COOKIE_MAX_AGE=31536000
DEVICE_APPROVAL_TOKEN_MAX_AGE=1800
DEVICE_APPROVAL_SALT=change-this-device-approval-salt


# ============================================================================
# 2D) OPTIONNEL - GOOGLE OAUTH ET YOUTUBE
# ============================================================================
# Necessaire seulement si tu veux :
# - connexion Google
# - synchronisation YouTube / import de playlists YouTube
#
# Tu peux reutiliser les memes credentials pour Google Login et YouTube Sync,
# ou separer les deux.

# Connexion Google.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:5000/google-callback

# Sync YouTube.
# Si vides, PulseBeat essaie de reutiliser GOOGLE_CLIENT_ID et
# GOOGLE_CLIENT_SECRET.
YOUTUBE_SYNC_CLIENT_ID=
YOUTUBE_SYNC_CLIENT_SECRET=

# Limites de sync YouTube pour les grosses playlists.
YOUTUBE_SYNC_MAX_TRACKS_PER_PLAYLIST=5000
YOUTUBE_SYNC_MAX_PLAYLIST_PAGES=20


# ============================================================================
# 2E) OPTIONNEL - CACHE SERVEUR ET PERFORMANCES
# ============================================================================
# Regle le cache local serveur pour les donnees publiques et l'audio YouTube.

# Racine locale du cache serveur.
# Vide = PulseBeat utilise `instance/server_cache`.
SERVER_CACHE_DIR=

# Taille/volume du cache JSON des donnees publiques.
SERVER_CACHE_JSON_MAX_BYTES=20971520
SERVER_CACHE_JSON_MAX_FILES=500

# TTL du cache texte/public.
PUBLIC_PROFILE_CACHE_TTL_SECONDS=180
PUBLIC_PLAYLIST_CACHE_TTL_SECONDS=180
POPULAR_PUBLIC_SONGS_CACHE_TTL_SECONDS=180

# Cache audio YouTube sur le serveur.
YOUTUBE_AUDIO_CACHE_ENABLED=1
YOUTUBE_AUDIO_CACHE_MAX_BYTES=536870912
YOUTUBE_AUDIO_CACHE_MAX_FILES=80


# ============================================================================
# 2F) OPTIONNEL - SURVEILLANCE DU STOCKAGE (507)
# ============================================================================
# PulseBeat peut se verrouiller en 507 si l'espace disque ou base semble plein.

# Espace libre minimal local (octets) avant de considerer le serveur "plein".
SERVER_STORAGE_MIN_FREE_BYTES=67108864

# Espace libre minimal cote base de donnees (octets) si l'information est
# disponible.
DATABASE_STORAGE_MIN_FREE_BYTES=67108864

# Capacite theorique de la base si Mongo/Atlas ne l'expose pas clairement.
# 0 = desactive l'override.
DATABASE_STORAGE_CAPACITY_BYTES=0


# ============================================================================
# 2G) OPTIONNEL - TIMEOUTS ET RESILIENCE SERVICE (408 / 503)
# ============================================================================
# Reglages du timeout adaptatif et du watchdog de surcharge.

# Budget de base d'une requete avant 408, sauf si PulseBeat detecte qu'il faut
# laisser plus de temps a une connexion lente mais plausible.
REQUEST_TIMEOUT_SECONDS=20

# Seuils de surcharge serveur pour activer le limp mode / latched mode.
SERVICE_OVERLOAD_ACTIVE_REQUESTS=18
SERVICE_OVERLOAD_BURST_REQUESTS=36
SERVICE_BURST_WINDOW_SECONDS=8
SERVICE_OVERLOAD_SLOW_REQUESTS=4
SERVICE_SLOW_WINDOW_SECONDS=180
SERVICE_LIMP_MODE_SECONDS=45
SERVICE_LATCH_OVERLOAD_EVENTS=3
SERVICE_LATCH_WINDOW_SECONDS=300
SERVICE_RECOVER_ACTIVE_REQUESTS=2
SERVICE_RECOVER_BURST_REQUESTS=6


# ============================================================================
# 2H) OPTIONNEL - WATCHDOG ANTI-ROBOT (429)
# ============================================================================
# Reglages du rate limiting comportemental et de la bascule vers la verif
# anti-robot.

ROBOT_WATCHDOG_WINDOW_SECONDS=8
ROBOT_WATCHDOG_MAX_REQUESTS=28
ROBOT_WATCHDOG_WRITE_WINDOW_SECONDS=20
ROBOT_WATCHDOG_MAX_WRITE_REQUESTS=10
ROBOT_WATCHDOG_BURST_WINDOW_SECONDS=2
ROBOT_WATCHDOG_MAX_BURST_REQUESTS=12
ROBOT_WATCHDOG_BLOCK_SECONDS=30
ROBOT_WATCHDOG_CHALLENGE_BLOCK_SECONDS=300
