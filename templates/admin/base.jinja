<!doctype html>
<html lang="{{ current_lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}{{ t('nav.admin') }} - {{ app_name }}{% endblock %}</title>
  <link rel="icon" type="image/svg+xml" href="{{ url_for('static', filename='favicon.svg') }}">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body class="admin-body">
  <header class="admin-header">
    <strong>{{ app_name }} - {{ t('nav.admin') }}</strong>
    <div class="row-actions">
      <a class="btn secondary" href="{{ url_for('main.index') }}">{{ t('nav.home') }}</a>
      <a class="btn" href="{{ url_for('accounts.logout') }}">{{ t('nav.logout') }}</a>
    </div>
  </header>
  <main class="page-container">
    {% with messages = get_flashed_messages(with_categories=true) %}
      {% if messages %}
        <div class="flash-list">
          {% for category, message in messages %}
            <div class="flash {{ category }}">{{ message }}</div>
          {% endfor %}
        </div>
      {% endif %}
    {% endwith %}
    {% block content %}{% endblock %}
  </main>
  <footer class="site-footer site-footer-admin">
    <div class="site-footer__inner">
      <span class="site-footer__brand">{{ app_name }}</span>
      <a href="{{ url_for('main.license_page') }}" class="site-footer__link">{{ t('nav.license') }}</a>
    </div>
  </footer>
  <template id="pulsebeat-form-honeypot-template">
    <div style="position:absolute;left:-10000px;top:auto;width:1px;height:1px;overflow:hidden;" aria-hidden="true">
      <label>{{ t('auth.robot_honeypot_label') }}
        <input type="text" name="{{ form_honeypot_name }}" tabindex="-1" autocomplete="off">
      </label>
    </div>
  </template>
  <script>
    (function () {
      const template = document.getElementById('pulsebeat-form-honeypot-template');
      if (!template) return;

      function hydrateForm(form) {
        if (!form || form.dataset.honeypotBound === '1') return;
        const method = (form.getAttribute('method') || 'get').toLowerCase();
        if (method !== 'post') return;
        if (form.querySelector('input[name="{{ form_honeypot_name }}"]')) {
          form.dataset.honeypotBound = '1';
          return;
        }
        const fragment = template.content.cloneNode(true);
        form.insertBefore(fragment, form.firstChild);
        form.dataset.honeypotBound = '1';
      }

      document.querySelectorAll('form').forEach(hydrateForm);
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          mutation.addedNodes.forEach((node) => {
            if (!(node instanceof Element)) return;
            if (node.matches('form')) hydrateForm(node);
            node.querySelectorAll && node.querySelectorAll('form').forEach(hydrateForm);
          });
        });
      });
      observer.observe(document.documentElement, { childList: true, subtree: true });
    })();

    window.CSRF_TOKEN = {{ csrf_token|tojson }};
    window.ADMIN_I18N = {
      alertDismissed: {{ t('admin.alert_dismissed')|tojson }},
      alertDismissFailed: {{ t('admin.alert_dismiss_failed')|tojson }},
      alertRestored: {{ t('admin.alert_restored')|tojson }},
      alertRestoreFailed: {{ t('admin.alert_restore_failed')|tojson }},
      undo: {{ t('player.menu.undo')|tojson }},
      userPickerNoResults: {{ t('search.no_results')|tojson }}
    };
    window.ADMIN_USER_CHOICES = {{ (admin_user_picker_choices or [])|tojson }};
  </script>
  <script src="{{ url_for('static', filename=client_js_asset('admin')) }}"></script>
</body>
</html>
