{% extends "layout/base.jinja" %}
{% block title %}{{ t('auth.forgot_password') }} - {{ app_name }}{% endblock %}

{% block content %}
<section class="auth-wrap">
  <div class="card auth-card">
    <h1>{{ t('auth.forgot_password') }}</h1>
    <p class="muted">{{ t('auth.forgot_password_help') }}</p>
    <form method="post" class="stack" data-validate-form="1">
      <label>{{ t('auth.email') }}
        <input type="email" name="email" required>
      </label>
      <button type="submit">{{ t('auth.send_reset_link') }}</button>
    </form>
    <p><a href="{{ url_for('accounts.login') }}">{{ t('auth.back_to_login') }}</a></p>
  </div>
</section>
{% endblock %}
