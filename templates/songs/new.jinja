{% extends "layout/base.jinja" %}
{% block title %}{{ t('main.add_song') }} - {{ app_name }}
  {% endblock %}

{% block content %}
<section class="page-stack">
  <div class="card feature-hero compact-hero">
    <div>
      <p class="hero-kicker">{{ app_name }}</p>
      <h1>{{ t('main.add_song') }}</h1>
      <p class="hero-copy">{{ t('songs.new_subtitle') }}</p>
    </div>
    <div class="hero-actions">
      <a class="btn secondary" href="{{ url_for('songs.my_songs') }}">{{ t('nav.my_songs') }}</a>
      <a class="btn secondary" href="{{ url_for('main.index') }}">{{ t('nav.home') }}</a>
    </div>
  </div>

  <section class="grid two-cols">
    <div class="card">
      <h2>{{ t('main.add_song') }}</h2>
      <form method="post" action="{{ url_for('songs.add_song') }}" enctype="multipart/form-data" class="stack" id="add-song-form" data-validate-form="1" data-require-source="1" data-source-url="song-url-input" data-source-file="song-file-input" data-private-visibility="visibility-select" data-private-target="song-shared-inputs">
        <label>{{ t('main.field.title') }}
          <input type="text" name="title" id="song-title-input" required>
        </label>
        <label>{{ t('main.field.artist') }}
          <input type="text" name="artist" id="song-artist-input">
        </label>
        <button type="button" id="retry-lyrics-btn" class="btn secondary" disabled>{{ t('song.lyrics_detect_button') }}</button>
        <label>{{ t('main.field.genre') }}
          <input type="text" name="genre" id="song-genre-input">
        </label>
        <label>{{ t('main.field.url') }}
          <input type="url" id="song-url-input" name="song_url" placeholder="https://.../audio.mp3">
        </label>
        <label>{{ t('main.field.file') }}
          <input type="file" name="song_file" id="song-file-input" accept=".mp3,.wav,.ogg,.m4a">
          <span id="id3-status" class="muted small"></span>
          <span id="lyrics-status" class="muted small"></span>
        </label>
        <input type="hidden" name="lyrics_text" id="song-lyrics-text-input" value="">
        <input type="hidden" name="lyrics_source" id="song-lyrics-source-input" value="">
        <div id="lyrics-file-wrap" class="stack hidden">
          <label>{{ t('song.lyrics_upload_optional') }}
            <input type="file" name="lyrics_file" id="lyrics-file-input" accept=".txt,.lrc">
          </label>
          <span class="muted small">{{ t('song.lyrics_upload_help') }}</span>
        </div>
        <label>{{ t('main.field.visibility') }}
          <select name="visibility" id="visibility-select">
            <option value="public">{{ t('main.visibility.public') }}</option>
            <option value="private">{{ t('main.visibility.private') }}</option>
            <option value="unlisted">{{ t('main.visibility.unlisted') }}</option>
          </select>
        </label>

        <div id="shared-with-wrap" class="hidden stack">
          <button
            type="button"
            class="btn secondary open-user-picker"
            data-target-inputs="song-shared-inputs"
            data-target-list="song-shared-list"
            data-picker-title="{{ t('main.share_with') }}" data-input-name="shared_with"
          >{{ t('main.share_with_add') }}</button>
          <div id="song-shared-list" class="selected-users"></div>
          <div id="song-shared-inputs"></div>
        </div>

        <button type="submit" id="add-song-submit">{{ t('main.add') }}</button>
      </form>
    </div>

    <div class="card feature-notes">
      <h2>{{ t('songs.new_tips_title') }}</h2>
      {% if current_lang == 'fr' %}
      <ul class="feature-list">
        <li>Ajoute un fichier audio propre (mp3/wav/ogg/m4a) pour maximiser la détection automatique des métadonnées.</li>
        <li>Après l'upload, PulseBeat essaie de remplir automatiquement le titre, l'artiste, le genre et les sous-titres.</li>
        <li>Le bouton "Ajouter des sous-titres automatiquement" permet de relancer la recherche après correction du titre ou de l'artiste.</li>
        <li>Si l'automatique échoue, ajoute un fichier <strong>.lrc</strong> pour activer la synchronisation avec la timeline.</li>
        <li>Un fichier <strong>.txt</strong> est accepté aussi, mais sans synchronisation temporelle automatique.</li>
        <li>Pour récupérer des lyrics manuellement, tu peux utiliser <a href="https://www.lyricsify.com/" target="_blank" rel="noopener noreferrer">Lyricsify</a>.</li>
        <li>Public = visible pour tous; Non répertoriée = visible via lien; Privée = partage ciblé avec utilisateurs sélectionnés.</li>
        <li>Après publication, tu seras redirigé vers "Mes chansons" pour vérifier immédiatement le résultat.</li>
      </ul>
      {% else %}
      <ul class="feature-list">
        <li>Upload a clean audio file (mp3/wav/ogg/m4a) to maximize automatic metadata detection.</li>
        <li>After upload, PulseBeat tries to auto-fill title, artist, genre, and subtitles.</li>
        <li>The "Add subtitles automatically" button lets you retry after updating title or artist fields.</li>
        <li>If auto-detection fails, upload a <strong>.lrc</strong> file to enable timeline synchronization.</li>
        <li>A <strong>.txt</strong> file is also supported, but without automatic time synchronization.</li>
        <li>For manual lyrics lookup, you can use <a href="https://www.lyricsify.com/" target="_blank" rel="noopener noreferrer">Lyricsify</a>.</li>
        <li>Public = visible to everyone; Unlisted = visible by link; Private = shared only with selected users.</li>
        <li>After publishing, you will be redirected to "My songs" for immediate verification.</li>
      </ul>
      {% endif %}
    </div>
  </section>
</section>

{% endblock %}
