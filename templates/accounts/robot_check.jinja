{% extends "layout/base.jinja" %}
{% block title %}{{ t('auth.robot_check_title') }} - {{ app_name }}{% endblock %}

{% block content %}
<section class="auth-wrap">
  <div class="card auth-card">
    <h1>{{ t('auth.robot_check_title') }}</h1>
    <p class="muted">{{ t('auth.robot_check_body') }}</p>
    <form method="post" class="stack" data-validate-form="1">
      <input type="hidden" name="next" value="{{ next_url }}">
      <label>{{ t('auth.robot_check_prompt') }}
        <div class="sub-card top-gap">
          <strong>{{ challenge_question }}</strong>
        </div>
      </label>
      <label>{{ t('auth.robot_check_answer_label') }}
        <input type="text" name="answer" inputmode="numeric" autocomplete="off" required>
      </label>
      <p class="muted small">{{ t('auth.robot_check_expiry', seconds=challenge_expires_seconds) }}</p>
      <button type="submit">{{ t('auth.robot_check_submit') }}</button>
    </form>
  </div>
</section>
{% endblock %}
